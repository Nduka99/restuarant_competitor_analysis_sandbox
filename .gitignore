*.md
!README.md
*.pdf
*.docx
*.pptx

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS noise ─────────────────────────────────────────────────
