# ── Virtual environment ──────────────────────────────────────
.venv/
venv/
env/

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Build artefacts ──────────────────────────────────────────
*.egg-info/
dist/
build/

# ── Secrets & config overrides ───────────────────────────────
.env
.env.*
!.env.example
secrets.yaml
configs/local_*.yaml

# ── Model weights (large binaries — store separately) ────────
*.gguf
*.bin
*.safetensors
models/

# ── Raw data (large, re-acquirable) ─────────────────────────
data/raw/
data/processed/
data/graph/
data/lancedb/

# ── Experiment outputs ───────────────────────────────────────
outputs/

# ── Local generators / helper scripts ────────────────────────
scripts/

